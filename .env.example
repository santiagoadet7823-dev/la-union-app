# ============================================================
# Variables de entorno — DisT-At
# Copiá este archivo a ".env.local" y completá los valores reales.
# .env.local NO se versiona (está en .gitignore).
# ============================================================

# --- Supabase (backend de producción: datos, realtime, auth, storage) ---
# Se obtienen en el panel de Supabase → Project Settings → API.
# La anon key es pública (segura en el front); la seguridad la dan las RLS.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Rol fijo de la app (para las APK nativas) ---
# vendedor | repartidor | (vacío = web Admin con selector de rol)
VITE_APP_ROLE=

# --- Google Maps (OPCIONAL) ---
# El mapa actual usa Leaflet/OSM + OSRM (gratis, sin key). Google es upgrade opcional.
# Maps JavaScript API + Directions API. Restringí por dominio/app en producción.
VITE_GOOGLE_MAPS_API_KEY=
