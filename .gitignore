node_modules
dist
dist-ssr
*.local
.DS_Store

# Capacitor native builds
# Ignore SELECTIVO: el código nativo escrito a mano (BatteryOptimizationPlugin.java,
# MainActivity.java, AndroidManifest.xml, build.gradle) NO lo regenera `cap add android`,
# así que debe quedar versionado. Solo ignoramos artefactos de build, config local y el
# keystore (el repo es público → las llaves de firma nunca se versionan).
/android/build
/android/.gradle
/android/app/build
/android/app/release
/android/local.properties
/android/keystore.properties
/android/app/*.keystore
/android/.idea
/android/*.iml
/android/app/*.iml
/android/capacitor-cordova-android-plugins
/ios

# Editor
.vscode/*
!.vscode/extensions.json
.idea

# Config local de Claude/preview (no versionar)
# OJO: el patrón debe ser `.claude/*` y no `.claude/`. Con la barra al final git
# excluye el directorio entero y ni siquiera desciende, así que el `!` de abajo
# nunca llegaría a aplicar y las skills quedarían fuera del repo.
.claude/*
# …salvo las skills de diseño, que SÍ se versionan (ver CLAUDE.md §9)
!.claude/skills/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Trabajos de diseño (no forman parte de la app)
trabajo diseñador ui ux/

# Artefacto de release OTA
bundle.zip

# Ícono fuente (se generan los mipmaps)
icon-fuente*.png

# Salida del parser graphify (artefacto regenerable de la auditoría)
graphify-out/
